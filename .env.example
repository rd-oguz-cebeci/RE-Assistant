# Example environment variables for local development
# Use either a proxy URL or the Atlassian MCP endpoint directly.
VITE_MCP_PROXY_URL=http://localhost:4000/api/mcp
#VITE_MCP_URL=https://mcp.atlassian.com/v1/mcp
#VITE_MCP_BEARER_TOKEN=your_mcp_token_here

# If one of these is configured, the app fetches MCP context and prepends it to
# the system prompt for every AI request.

# Note: API keys are stored by the app in localStorage via the Settings UI.
# You can also provide a default key here if you want to prefill during development
# (not recommended for production):
# VITE_API_KEY=your_gemini_or_anthropic_api_key_here
